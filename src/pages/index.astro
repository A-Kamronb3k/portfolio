---
import Layout from '../layouts/Layout.astro';

const pageTitle = 'Kamronbek Allanazarov — Cloud Engineer';
const pageDescription =
	'Aspiring cloud engineer building AWS infrastructure with Terraform, Docker, and CI/CD — measured, automated, and cost-aware.';

const timeline = [
	{
		title: 'Cloud Engineering Program — IT Park Uzbekistan, Samarkand',
		dates: 'Apr – Aug 2026',
		description:
			'State-funded program backed by the Ministry of Digital Technologies and the World Bank; AIUB-based curriculum, taught in English. Final certification exam — end of August.',
	},
	{
		title: '29-Day Cloud Portfolio Sprint (self-directed)',
		dates: 'Jun–Jul 2026',
		description:
			'Four production-style AWS projects, built in public at $0 — live demos, CI/CD, IaC, security scanning.',
	},
	{
		title: "Frontend Development (React) — Najot Ta'lim",
		dates: 'Dec 2023 – Sep 2024',
		description:
			'Completed a hands-on frontend bootcamp: JavaScript, React, responsive UI.',
	},
	{
		title: 'B.Sc. Digital Economy — Tashkent State University of Economics',
		dates: '2021 – 2025',
		description: 'Where the cost-awareness comes from.',
	},
];

const buildingSkills = [
	{
		name: 'AWS',
		details: ['S3', 'CloudFront', 'IAM', 'Budgets'],
		note: 'Services used in live projects',
	},
	{
		name: 'Docker',
		details: ['Multi-stage builds', 'Non-root containers', 'Healthchecks'],
	},
	{
		name: 'GitHub Actions',
		details: ['OIDC keyless deploys', 'Trivy scanning', 'GHCR publishing'],
	},
	{
		name: 'Git & Linux CLI',
		details: ['Version control workflows', 'Shell scripting & server ops'],
	},
	{
		name: 'Terraform',
		details: ['Learning-by-building', 'Serverless project in progress'],
	},
];

const foundationSkills = [
	'JavaScript & React (bootcamp 2023–24)',
	'Python (basics)',
	'HTML/CSS',
	'Astro',
];

const projects = [
	{
		title: 'AWS Static Site + CI/CD',
		description:
			'Private S3 + CloudFront (OAC), deployed by OIDC GitHub Actions.',
		chips: ['S3', 'CloudFront', 'GitHub Actions', 'OIDC'],
		liveUrl: 'https://dtx8c9l8wd3k9.cloudfront.net',
		githubUrl: 'https://github.com/A-Kamronb3k/aws-static-site-cicd',
	},
	{
		title: 'Dockerized Feedback API',
		description:
			'Multi-stage, non-root container; CI with Trivy scanning, published to GHCR, live on Render.',
		chips: ['Docker', 'Trivy', 'GHCR', 'Express'],
		liveUrl: 'https://dockerized-feedback-api-latest.onrender.com',
		githubUrl: 'https://github.com/A-Kamronb3k/dockerized-feedback-api',
	},
];
---

<Layout title={pageTitle} description={pageDescription}>
	<section id="hero" class="section hero" aria-labelledby="hero-heading">
		<div class="container">
			<div class="hero-grid">
				<div class="hero-content">
					<p class="hero-eyebrow">Portfolio</p>
					<h1 id="hero-heading">Kamronbek Allanazarov</h1>
					<p class="hero-role">Aspiring Cloud Engineer — AWS · Terraform · Docker · CI/CD</p>
					<p class="hero-tagline measure">
						I build cloud infrastructure the way an economist would — measured, automated,
						and cost-aware. Everything below runs live, for $0.
					</p>
					<div class="hero-actions">
						<a class="btn btn-primary" href="#projects">View Projects</a>
						<a
							class="btn btn-secondary"
							href="https://github.com/A-Kamronb3k"
							target="_blank"
							rel="noopener noreferrer"
						>
							GitHub
						</a>
					</div>
				</div>

				<aside class="terminal" aria-hidden="true">
					<div class="terminal-bar">
						<span class="terminal-dot" />
						<span class="terminal-dot" />
						<span class="terminal-dot" />
					</div>
					<pre class="terminal-body"><code><span class="terminal-prompt">$</span> aws s3 sync ./dist s3://portfolio --delete
<span class="terminal-prompt">$</span> terraform apply -auto-approve
<span class="terminal-success">✔</span> deploy complete — cost: $0.00</code></pre>
				</aside>
			</div>
		</div>
	</section>

	<section id="about" class="section" aria-labelledby="about-heading">
		<div class="container">
			<h2 id="about-heading" class="section-heading">About</h2>
			<p class="intro measure">
				I started in economics, moved through frontend, and found the part of software I
				actually love: what happens after <code>git push</code>. Now I design and ship AWS
				infrastructure — documented like production systems, with budget alarms,
				least-privilege IAM, and security scanning in every pipeline. I write down what
				breaks and how I fix it — mistakes included.
			</p>

			<ol class="timeline" aria-label="Education and experience">
				{
					timeline.map((item) => (
						<li class="timeline-item">
							<div class="timeline-marker" aria-hidden="true" />
							<div class="timeline-content">
								<h3 class="timeline-title">{item.title}</h3>
								<time class="timeline-dates" datetime={item.dates}>{item.dates}</time>
								<p class="timeline-description measure">{item.description}</p>
							</div>
						</li>
					))
				}
			</ol>
		</div>
	</section>

	<section id="skills" class="section" aria-labelledby="skills-heading">
		<div class="container">
			<h2 id="skills-heading" class="section-heading">Skills</h2>

			<div class="skills-group">
				<h3 class="skills-group-heading">Building with (every item backed by a public repo)</h3>
				<ul class="skill-cards">
					{
						buildingSkills.map((skill) => (
							<li class="skill-card">
								<h4 class="skill-name">{skill.name}</h4>
								<ul class="skill-details">
									{skill.details.map((detail) => (
										<li>{detail}</li>
									))}
								</ul>
								{skill.note && <p class="skill-note">{skill.note}</p>}
							</li>
						))
					}
				</ul>
				<p class="skills-footnote measure">
					Ask me about any of these in an interview — I can open the repo and walk through
					it.
				</p>
			</div>

			<div class="skills-group">
				<h3 class="skills-group-heading">Foundations</h3>
				<ul class="foundation-list">
					{foundationSkills.map((skill) => <li>{skill}</li>)}
				</ul>
			</div>
		</div>
	</section>

	<section id="projects" class="section" aria-labelledby="projects-heading">
		<div class="container">
			<h2 id="projects-heading" class="section-heading">Projects</h2>
			<p class="projects-intro measure">
				Full project cards are on the way — two are already live:
			</p>
			<ul class="project-grid">
				{
					projects.map((project) => (
						<li class="project-card">
							<h3 class="project-title">{project.title}</h3>
							<p class="project-description measure">{project.description}</p>
							<ul class="project-chips" aria-label="Technologies used">
								{project.chips.map((chip) => (
									<li>{chip}</li>
								))}
							</ul>
							<div class="project-actions">
								<a
									class="btn btn-primary btn-sm"
									href={project.liveUrl}
									target="_blank"
									rel="noopener noreferrer"
								>
									Live Demo
									<span class="sr-only"> — {project.title} (opens in new tab)</span>
								</a>
								<a
									class="btn btn-secondary btn-sm"
									href={project.githubUrl}
									target="_blank"
									rel="noopener noreferrer"
								>
									GitHub
									<span class="sr-only"> — {project.title} (opens in new tab)</span>
								</a>
							</div>
						</li>
					))
				}
			</ul>
			<p class="projects-note measure">Two more projects shipping soon — built in public.</p>
		</div>
	</section>

	<section id="contact" class="section contact" aria-labelledby="contact-heading">
		<div class="container">
			<h2 id="contact-heading" class="sr-only">Contact</h2>
			<div class="contact-strip">
				<p class="contact-label">Let's talk:</p>
				<div class="contact-actions">
					<a
						class="btn btn-secondary btn-sm"
						href="https://github.com/A-Kamronb3k"
						target="_blank"
						rel="noopener noreferrer"
					>
						GitHub
						<span class="sr-only"> (opens in new tab)</span>
					</a>
					<a
						class="btn btn-secondary btn-sm"
						href="https://t.me/Kamronbek_Allanazarov"
						target="_blank"
						rel="noopener noreferrer"
					>
						Telegram
						<span class="sr-only"> (opens in new tab)</span>
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	:root {
		--color-bg: #0f0f0f;
		--color-surface: #1a1a1a;
		--color-border: #2e2e2e;
		--color-text: #e8e8e8;
		--color-text-muted: #a0a0a0;
		--color-accent: #ff9900;
		--color-accent-hover: #ffb84d;
		--container-max: 68.75rem;
		--container-padding: clamp(1rem, 4vw, 1.5rem);
		--section-gap: clamp(5rem, 10vw, 7.5rem);
		--measure: 70ch;
		--font-mono: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas,
			monospace;
	}

	.container {
		width: 100%;
		max-width: var(--container-max);
		margin: 0 auto;
		padding-inline: var(--container-padding);
	}

	.measure {
		max-width: var(--measure);
	}

	.section + .section {
		padding-top: var(--section-gap);
	}

	.section-heading {
		margin: 0 0 1.75rem;
		font-size: clamp(1.5rem, 3vw, 1.875rem);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.section-heading::after {
		content: '';
		display: block;
		width: 2.5rem;
		height: 3px;
		margin-top: 0.625rem;
		background: var(--color-accent);
		border-radius: 2px;
	}

	/* Hero */
	.hero {
		padding-top: clamp(1.5rem, 4vw, 2.5rem);
	}

	.hero-grid {
		display: grid;
		gap: 2.5rem;
		align-items: center;
	}

	@media (min-width: 768px) {
		.hero-grid {
			grid-template-columns: 1fr 1fr;
			gap: 3rem;
		}
	}

	.hero-eyebrow {
		margin: 0 0 0.75rem;
		color: var(--color-accent);
		font-size: 0.875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.hero h1 {
		margin: 0 0 0.75rem;
		font-size: clamp(2rem, 5vw, 3rem);
		font-weight: 800;
		line-height: 1.15;
		letter-spacing: -0.03em;
	}

	.hero-role {
		margin: 0 0 1.25rem;
		color: var(--color-text-muted);
		font-size: clamp(1rem, 2.5vw, 1.125rem);
		font-weight: 500;
	}

	.hero-tagline {
		margin: 0 0 2rem;
		font-size: 1.0625rem;
		line-height: 1.7;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.terminal {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.625rem;
		overflow: hidden;
		box-shadow: 0 1rem 2.5rem rgb(0 0 0 / 25%);
	}

	.terminal-bar {
		display: flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.625rem 0.875rem;
		background: color-mix(in srgb, var(--color-border) 40%, var(--color-surface));
		border-bottom: 1px solid var(--color-border);
	}

	.terminal-dot {
		width: 0.625rem;
		height: 0.625rem;
		border-radius: 50%;
		background: var(--color-border);
	}

	.terminal-dot:first-child {
		background: #ff5f57;
	}

	.terminal-dot:nth-child(2) {
		background: #febc2e;
	}

	.terminal-dot:nth-child(3) {
		background: #28c840;
	}

	.terminal-body {
		margin: 0;
		padding: 1.25rem 1rem;
		overflow-x: auto;
		font-family: var(--font-mono);
		font-size: 0.8125rem;
		line-height: 1.7;
		color: var(--color-text-muted);
	}

	.terminal-body code {
		font-family: inherit;
	}

	.terminal-prompt {
		color: var(--color-accent);
	}

	.terminal-success {
		color: #28c840;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.625rem 1.25rem;
		font-size: 0.9375rem;
		font-weight: 600;
		text-decoration: none;
		border-radius: 0.375rem;
		border: 2px solid transparent;
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease,
			box-shadow 0.2s ease;
	}

	.btn-sm {
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
	}

	.btn:focus-visible {
		outline: 2px solid var(--color-accent);
		outline-offset: 3px;
	}

	.btn-primary {
		background: var(--color-accent);
		color: #0f0f0f;
	}

	.btn-primary:hover {
		background: var(--color-accent-hover);
	}

	.btn-secondary {
		background: transparent;
		color: var(--color-text);
		border-color: var(--color-border);
	}

	.btn-secondary:hover {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	/* About */
	.intro {
		margin: 0 0 3rem;
		font-size: 1.0625rem;
		line-height: 1.75;
	}

	.intro code {
		padding: 0.125rem 0.375rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.25rem;
		font-size: 0.9em;
	}

	.timeline {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.timeline-item {
		display: grid;
		grid-template-columns: 1.25rem 1fr;
		gap: 0 1.5rem;
		padding-bottom: 2.25rem;
	}

	.timeline-item:last-child {
		padding-bottom: 0;
	}

	.timeline-marker {
		position: relative;
		width: 100%;
	}

	.timeline-marker::before {
		content: '';
		position: absolute;
		top: 0.4rem;
		left: 50%;
		width: 0.625rem;
		height: 0.625rem;
		background: var(--color-accent);
		border-radius: 50%;
		transform: translateX(-50%);
	}

	.timeline-marker::after {
		content: '';
		position: absolute;
		top: 1.125rem;
		left: 50%;
		width: 2px;
		height: calc(100% + 1.75rem);
		background: var(--color-border);
		transform: translateX(-50%);
	}

	.timeline-item:last-child .timeline-marker::after {
		display: none;
	}

	.timeline-title {
		margin: 0 0 0.25rem;
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.4;
	}

	.timeline-dates {
		display: block;
		margin: 0 0 0.5rem;
		color: var(--color-accent);
		font-size: 0.875rem;
		font-weight: 500;
	}

	.timeline-description {
		margin: 0;
		color: var(--color-text-muted);
		font-size: 0.9375rem;
		line-height: 1.65;
	}

	/* Skills */
	.skills-group + .skills-group {
		margin-top: 3rem;
	}

	.skills-group-heading {
		margin: 0 0 1.5rem;
		font-size: 1.0625rem;
		font-weight: 600;
	}

	.skill-cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	@media (min-width: 900px) {
		.skill-cards {
			grid-template-columns: repeat(6, 1fr);
		}

		.skill-card:nth-child(-n + 3) {
			grid-column: span 2;
		}

		.skill-card:nth-child(n + 4) {
			grid-column: span 3;
		}
	}

	.skill-card {
		padding: 1.25rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.skill-card:hover {
		transform: translateY(-3px);
		border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-border));
		box-shadow: 0 0.5rem 1.25rem rgb(0 0 0 / 20%);
	}

	.skill-name {
		margin: 0 0 0.75rem;
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-accent);
	}

	.skill-details {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.skill-details li {
		position: relative;
		padding-left: 1rem;
		color: var(--color-text-muted);
		font-size: 0.875rem;
		line-height: 1.5;
	}

	.skill-details li + li {
		margin-top: 0.375rem;
	}

	.skill-details li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55em;
		width: 0.3rem;
		height: 0.3rem;
		background: var(--color-border);
		border-radius: 50%;
	}

	.skill-note {
		margin: 0.75rem 0 0;
		padding-top: 0.75rem;
		border-top: 1px solid var(--color-border);
		color: var(--color-text-muted);
		font-size: 0.8125rem;
		font-style: italic;
	}

	.skills-footnote {
		margin: 1.5rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.875rem;
		font-style: italic;
	}

	.foundation-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.foundation-list li {
		padding: 0.375rem 0.75rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 999px;
		font-size: 0.875rem;
	}

	/* Projects */
	.projects-intro {
		margin: 0 0 1.75rem;
		color: var(--color-text-muted);
		font-size: 1rem;
	}

	.project-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	@media (min-width: 640px) {
		.project-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.project-card {
		display: flex;
		flex-direction: column;
		padding: 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
	}

	.project-title {
		margin: 0 0 0.625rem;
		font-size: 1.0625rem;
		font-weight: 700;
		line-height: 1.35;
	}

	.project-description {
		flex: 1;
		margin: 0 0 1rem;
		color: var(--color-text-muted);
		font-size: 0.9375rem;
		line-height: 1.6;
	}

	.project-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.375rem;
		margin: 0 0 1.25rem;
		padding: 0;
		list-style: none;
	}

	.project-chips li {
		padding: 0.2rem 0.5rem;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 0.25rem;
		color: var(--color-text-muted);
		font-size: 0.75rem;
		font-weight: 500;
	}

	.project-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: auto;
	}

	.projects-note {
		margin: 1.5rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.875rem;
		font-style: italic;
	}

	/* Contact */
	.contact-strip {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 1rem 1.5rem;
		padding: 1.5rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
	}

	.contact-label {
		margin: 0;
		font-size: 1rem;
		font-weight: 600;
	}

	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 480px) {
		.timeline-item {
			grid-template-columns: 1rem 1fr;
			gap: 0 1rem;
		}

		.contact-strip {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
